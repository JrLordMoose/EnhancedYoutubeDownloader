<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EnhancedYoutubeDownloader.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="420"
             x:Class="EnhancedYoutubeDownloader.Views.Dialogs.AuthSetupDialog"
             x:DataType="vm:AuthSetupViewModel"
             Width="560" Height="420">

    <Border Background="{DynamicResource MaterialDesignPaper}"
            CornerRadius="8"
            Padding="24"
            BoxShadow="0 8 16 0 #40000000">

        <StackPanel Spacing="16">
            <TextBlock Text="Authentication"
                       FontSize="20"
                       FontWeight="SemiBold"/>

            <TextBlock TextWrapping="Wrap" FontSize="14">
                Sign in with Google inside the app is not available yet. For private, unlisted, or age-restricted videos, enable browser cookie authentication in Settings.
            </TextBlock>

            <Border Background="#FFF3E0"
                    BorderBrush="#FFB74D"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="Recommended: Browser cookies"
                              FontWeight="Medium"
                              Foreground="#E65100"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#E65100">
                        Uses cookies from Chrome, Firefox, Edge, Brave, Opera, or Chromium on this PC. Credentials stay local and are never sent to third-party servers.
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Status}" FontWeight="Medium"/>
                <TextBlock Text="{Binding BrowserLabel, StringFormat='Browser: {0}'}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Clear cookies"
                        Command="{Binding ClearBrowserCookiesCommand}"
                        IsEnabled="{Binding IsBrowserCookiesEnabled}"
                        Theme="{DynamicResource MaterialOutlineButton}"
                        MinWidth="120"/>
                <Button Content="Open Settings"
                        Command="{Binding OpenAuthenticationSettingsCommand}"
                        Theme="{DynamicResource MaterialRaisedButton}"
                        MinWidth="120"/>
                <Button Content="Close"
                        Command="{Binding CloseDialogCommand}"
                        Theme="{DynamicResource MaterialOutlineButton}"
                        MinWidth="100"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
